#include <stdlib.h>

int maxEqualFreq(int* nums, int numsSize) {
    int count[100001] = {0};  
    int freq[100001] = {0};    

    int maxFreq = 0;
    int ans = 0;

    for (int i = 0; i < numsSize; i++) {
        int x = nums[i];

        if (count[x] > 0)
            freq[count[x]]--;

       
        count[x]++;
        freq[count[x]]++;

        if (count[x] > maxFreq)
            maxFreq = count[x];

        int len = i + 1;

        
        if (maxFreq == 1) {
            ans = len;
        }
        else if (freq[maxFreq] == 1 &&
                 freq[maxFreq] * maxFreq +
                 freq[maxFreq - 1] * (maxFreq - 1) == len) {
            ans = len;
        }
       else if (freq[1]=1 && (freq[maxFreq] * maxFreq +1 ==len))
       {
                ans=len;
       }
    }
    return ans;
}
