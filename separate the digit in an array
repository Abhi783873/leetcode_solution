#include <stdio.h>
#include <stdlib.h>

int* separateDigits(int* nums, int numsSize, int* returnSize) {

    int total = 0;
    for (int i = 0; i < numsSize; i++) {
        int x = nums[i];
        while (x > 0) {
            total++;
            x /= 10;
        }
    }

    *returnSize = total;
    int* result = (int*)malloc(total * sizeof(int));

    int idx = 0;

    for (int i = 0; i < numsSize; i++) {
        int x = nums[i];

 
        int temp[10];
        int len = 0;

        while (x > 0) {
            temp[len++] = x % 10;
            x /= 10;
        }

 
        for (int j = len - 1; j >= 0; j--) {
            result[idx++] = temp[j];
        }
    }

    return result;
}
