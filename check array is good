#include <stdbool.h>

bool isGood(int* nums, int numsSize) {
    int n = numsSize - 1;
    int freq[2001] = {0}; 

    for (int i = 0; i < numsSize; i++) {
        if (nums[i] > n || nums[i] < 1) return false;
        freq[nums[i]]++;
    }

    for (int i = 1; i < n; i++) {
        if (freq[i] != 1) return false;
    }

    return freq[n] == 2;
}
